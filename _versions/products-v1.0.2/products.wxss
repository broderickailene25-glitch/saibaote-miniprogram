/* pages/products/products.wxss - 赛宝特产品页（喜茶式高级极简点单风） */

page {
  --color-bg: #FAF9F7;
  --color-nav: #2D2D2D;
  --color-card-bg: #FFFFFF;
  --color-text-primary: #2D2D2D;
  --color-text-secondary: #8C8C8C;
  --color-text-light: #BFBFBF;
  --color-tag-border: #E8E6E1;
  --color-tag-gold: #C4A87C;
  --color-divider: #EFEDE8;
  --color-price: #2D2D2D;
  --color-green-accent: #3A6B4F;
  --color-banner-bg: #F7F5F0;
}

.page-products {
  min-height: 100vh;
  background: var(--color-bg);
  display: flex;
  flex-direction: column;
}

/* ==================== 顶部深炭灰色导航区 ==================== */
.top-nav {
  background: #2A2A2A;
  padding: 0 28rpx;
}

/* 状态栏占位 — 适配刘海/灵动岛 */
.status-bar-placeholder {
  height: 44px;
  height: constant(safe-area-inset-top);
  height: env(safe-area-inset-top);
}

.nav-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 100rpx 0 4rpx;
}

.nav-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.store-switch {
  display: flex;
  align-items: center;
}

.switch-item {
  font-size: 24rpx;
  color: rgba(243, 241, 236, 0.5);
  letter-spacing: 1rpx;
}

.switch-item.active {
  font-size: 36rpx;
  color: #F3F1EC;
  font-weight: 600;
}

.store-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.store-name {
  font-size: 34rpx;
  font-weight: 800;
  color: #F3F1EC;
  letter-spacing: 1rpx;
}

.store-dist {
  font-size: 22rpx;
  color: rgba(243, 241, 236, 0.4);
}

/* 一起选横幅 */
.together-banner {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  margin: 6rpx 0 12rpx;
}

.together-sub {
  font-size: 20rpx;
  color: rgba(243, 241, 236, 0.55);
  letter-spacing: 4rpx;
}

/* ==================== 品牌宣传卡片（白底双卡） ==================== */
.brand-section {
  background: linear-gradient(to bottom, #2A2A2A 20%, #FAF9F7 20%);
  padding-bottom: 60rpx;
}

.brand-cards-area {
  display: flex;
  gap: 24rpx;
  padding: 16rpx 28rpx 0;
}

.brand-card-group {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.brand-card-img {
  width: 100%;
  height: 280rpx;
  background: #FFFFFF;
  overflow: hidden;
}

.card-image {
  width: 100%;
  height: 100%;
  display: block;
}

.brand-card-text {
  width: 100%;
  height: 148rpx;
  box-sizing: border-box;
  background: #FFFFFF;
  padding: 16rpx 18rpx 16rpx 38rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 6rpx;
  border: 2rpx solid #EFEDE8;
  border-top: none;
}

.card-title {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  letter-spacing: 4rpx;
  line-height: 1.4;
}

.card-subtitle {
  font-size: 15rpx;
  color: var(--color-text-secondary);
  letter-spacing: 2rpx;
  line-height: 1.3;
}

/* ==================== 主体区域 ==================== */
.main-area {
  flex: 1;
  display: flex;
  padding: 24rpx 0 0;
}

/* 左侧分类导航 */
.category-nav {
  width: 150rpx;
  flex-shrink: 0;
  height: calc(100vh - 520rpx);
  padding: 0;
}

.cat-item {
  padding: 28rpx 0;
  text-align: center;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cat-indicator {
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 4rpx;
  height: 0;
  background: var(--color-text-primary);
  border-radius: 0 4rpx 4rpx 0;
  transition: height 0.2s ease;
}

.cat-item.active .cat-indicator {
  height: 32rpx;
}

.cat-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  letter-spacing: 0.5rpx;
  transition: all 0.2s ease;
}

.cat-item.active .cat-text {
  color: var(--color-text-primary);
  font-weight: 600;
}

/* 右侧商品列表 */
.product-list {
  flex: 1;
  padding: 0 28rpx 0 20rpx;
  height: calc(100vh - 520rpx);
}

/* 分类标题 */
.section-header {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  padding: 0 0 20rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  letter-spacing: 0.5rpx;
}

.section-count {
  font-size: 22rpx;
  color: var(--color-text-light);
}

/* 商品卡片 */
.product-card {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 2rpx solid var(--color-divider);
  gap: 20rpx;
}

.product-card:last-child {
  border-bottom: none;
}

/* 产品图片（白底） */
.product-img-wrap {
  width: 170rpx;
  height: 170rpx;
  flex-shrink: 0;
  background: #FFFFFF;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid var(--color-divider);
}

.product-img {
  width: 80%;
  height: 80%;
}

/* 产品信息 */
.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
  padding: 4rpx 0;
}

.product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 标签 */
.product-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}

.tag {
  font-size: 18rpx;
  color: var(--color-tag-gold);
  border: 2rpx solid rgba(196, 168, 124, 0.3);
  padding: 2rpx 14rpx;
  border-radius: 999rpx;
  line-height: 1.6;
}

.product-subtitle {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 底部：规格 + 价格/操作 */
.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
  padding-top: 12rpx;
}

.product-spec {
  font-size: 20rpx;
  color: var(--color-text-light);
}

.price-action {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.price {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-price);
}

.price.contact {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
}

.btn-add {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid var(--color-divider);
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
}

.btn-add-text {
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 300;
  line-height: 1;
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-text {
  font-size: 26rpx;
  color: var(--color-text-light);
}

/* ==================== 底部留白 ==================== */
.bottom-spacer {
  height: 140rpx;
}
