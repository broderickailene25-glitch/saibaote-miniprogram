/* components/section-header/section-header.wxss */

.section-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: 0 32rpx;
  margin-bottom: 40rpx;
}

.header-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.header-title {
  font-size: var(--font-xl);
  font-weight: 500;
  color: var(--text-primary);
  line-height: 1.3;
}

.header-subtitle {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  line-height: 1.4;
}

.header-more {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 0;
}

.more-text {
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

.more-arrow {
  font-size: 32rpx;
  color: var(--text-tertiary);
  font-weight: 300;
}
