/* components/share-banner/share-banner.wxss - 通用分享横幅 */

.share-banner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 18rpx 36rpx;
  margin: 16rpx 0;
  background: #2C2C2C;
  min-height: 80rpx;
  width: 750rpx;
  position: relative;
  left: 50%;
  transform: translateX(-50%);
}

.share-banner:active {
  opacity: 0.9;
}

.icon {
  font-size: 28rpx;
  flex-shrink: 0;
  line-height: 1;
}

.text {
  font-size: 24rpx;
  color: #FAFAF8;
  letter-spacing: 1rpx;
  font-weight: 400;
  line-height: 1.3;
}

.highlight {
  color: #D4A373;
  font-weight: 500;
}

.arrow {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.35);
  flex-shrink: 0;
  line-height: 1;
}
