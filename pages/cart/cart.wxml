<!--pages/cart/cart.wxml — Aesop式编辑清单-->
<view class="page-cart">

  <!-- 自定义导航栏 -->
  <nav-bar title="购物车" showBack="{{true}}" bind:lefttap="onNavBack"></nav-bar>

  <!-- 分享横幅 -->
  <share-banner></share-banner>

  <!-- ==================== 购物车列表 ==================== -->
  <view class="cart-list" wx:if="{{cartItems.length > 0}}">
    <view class="cart-item" wx:for="{{cartItems}}" wx:key="id">

      <!-- 产品图片 -->
      <image
        class="item-img"
        src="{{item.image}}"
        mode="aspectFill"
        lazy-load
        bindtap="goToDetail"
        data-id="{{item.id}}"
      ></image>

      <!-- 产品信息 -->
      <view class="item-info">
        <text class="item-name" bindtap="goToDetail" data-id="{{item.id}}">{{item.name}}</text>
        <text class="item-spec">{{item.unit}}</text>

        <view class="item-row">
          <text class="item-price">¥{{item.price}}</text>
          <view class="item-qty">
            <view class="qty-btn" catchtap="decreaseQty" data-id="{{item.id}}">
              <text>−</text>
            </view>
            <text class="qty-num">{{item.quantity}}</text>
            <view class="qty-btn" catchtap="increaseQty" data-id="{{item.id}}">
              <text>+</text>
            </view>
          </view>
        </view>

        <text class="item-remove" catchtap="removeItem" data-id="{{item.id}}">移除</text>
      </view>

    </view>
  </view>

  <!-- ==================== 空状态 ==================== -->
  <view class="empty-state" wx:if="{{cartItems.length === 0}}">
    <text class="empty-icon">🛒</text>
    <text class="empty-text">购物车是空的</text>
    <view class="empty-btn" bindtap="goToProducts">
      <text>去逛逛</text>
    </view>
  </view>

  <!-- ==================== 底部结算栏 ==================== -->
  <view class="footer" wx:if="{{cartItems.length > 0}}">
    <view class="footer-left">
      <text class="footer-total">¥{{totalPrice}}</text>
      <text class="footer-count">共 {{totalCount}} 件</text>
    </view>
    <view class="footer-btn" bindtap="goToOrder">
      <text>去结算</text>
    </view>
  </view>

  <!-- 底部留白 -->
  <view class="bottom-spacer" wx:if="{{cartItems.length > 0}}"></view>

</view>
