/* pages/cart/cart.wxss — Aesop式编辑清单 */

page {
  --bg: #FAFAF8;
  --text: #2C2C2C;
  --text-light: #888888;
  --text-muted: #AAAAAA;
  --border: #EEEEEE;
  --border-footer: #E8E4DE;
}

.page-cart {
  min-height: 100vh;
  background: var(--bg);
}

/* ==================== 购物车列表 ==================== */
.cart-list {
  padding: 40rpx 56rpx 0;
}

.cart-item {
  display: flex;
  gap: 40rpx;
  padding: 48rpx 0;
  border-bottom: 1rpx solid var(--border);
  align-items: flex-start;
}

.cart-item:first-child {
  border-top: 1rpx solid var(--border);
}

/* 产品图片 */
.item-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 4rpx;
  flex-shrink: 0;
}

/* 产品信息 */
.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  min-width: 0;
}

.item-name {
  font-family: Georgia, "Songti SC", serif;
  font-size: 30rpx;
  color: var(--text);
  line-height: 1.3;
}

.item-spec {
  font-size: 22rpx;
  font-weight: 300;
  color: var(--text-muted);
  letter-spacing: 2rpx;
}

/* 价格 + 数量控件 */
.item-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}

.item-price {
  font-family: Georgia, "Songti SC", serif;
  font-size: 36rpx;
  color: var(--text);
}

/* 纯文字 ± 数量控件 */
.item-qty {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  border: 1rpx solid #DDD;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qty-btn text {
  font-size: 28rpx;
  color: var(--text);
  line-height: 1;
}

.qty-btn:active {
  opacity: 0.6;
}

.qty-num {
  font-size: 26rpx;
  font-weight: 400;
  color: var(--text);
  min-width: 40rpx;
  text-align: center;
}

/* 移除 */
.item-remove {
  font-size: 22rpx;
  color: #CCC;
  letter-spacing: 2rpx;
  margin-top: 16rpx;
}

.item-remove:active {
  opacity: 0.5;
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 240rpx 56rpx;
}

.empty-icon {
  font-size: 80rpx;
  opacity: 0.2;
  margin-bottom: 48rpx;
}

.empty-text {
  font-size: 26rpx;
  font-weight: 300;
  color: var(--text-muted);
  letter-spacing: 4rpx;
  margin-bottom: 80rpx;
}

.empty-btn {
  padding: 28rpx 80rpx;
  border: 1rpx solid #DDD;
  background: none;
}

.empty-btn text {
  font-size: 20rpx;
  font-weight: 500;
  letter-spacing: 6rpx;
  color: var(--text);
}

.empty-btn:active {
  opacity: 0.6;
}

/* ==================== 底部结算栏 ==================== */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 192rpx;
  background: var(--bg);
  border-top: 1rpx solid var(--border-footer);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 56rpx;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 100;
}

.footer-left {
  display: flex;
  align-items: baseline;
  gap: 32rpx;
}

.footer-total {
  font-family: Georgia, "Songti SC", serif;
  font-size: 48rpx;
  color: var(--text);
}

.footer-count {
  font-size: 22rpx;
  font-weight: 300;
  color: var(--text-muted);
  letter-spacing: 2rpx;
}

.footer-btn {
  height: 88rpx;
  padding: 0 72rpx;
  background: var(--text);
  color: var(--bg);
  display: flex;
  align-items: center;
  justify-content: center;
}

.footer-btn text {
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 6rpx;
}

.footer-btn:active {
  opacity: 0.85;
}

/* ==================== 底部留白 ==================== */
.bottom-spacer {
  height: 240rpx;
}
