/* pages/cart/cart.wxss - 购物车页样式 */

.page-cart {
  min-height: 100vh;
  background: var(--bg);
}

/* ==================== 购物车列表 ==================== */
.cart-list {
  padding: 32rpx 48rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.cart-item {
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
}

/* 产品图片 */
.item-img-wrap {
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  flex-shrink: 0;
}

.item-img {
  width: 100%;
  height: 100%;
}

/* 产品信息 */
.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.item-name {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
  flex: 1;
}

.item-delete {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
}

.delete-icon {
  font-size: 40rpx;
  color: var(--text-tertiary);
  line-height: 1;
}

.item-subtitle {
  font-size: var(--font-xs);
  color: var(--text-tertiary);
  margin-bottom: 16rpx;
}

.item-price {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

/* 数量调整 */
.quantity-bar {
  display: flex;
  align-items: center;
  gap: 0;
  align-self: flex-end;
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg);
  border-radius: var(--radius-sm);
  font-size: var(--font-lg);
  color: var(--text-primary);
}

.qty-btn.disabled {
  color: var(--text-placeholder);
}

.qty-btn:active {
  background: var(--border-light);
}

.qty-number {
  width: 80rpx;
  text-align: center;
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 48rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: var(--font-lg);
  color: var(--text-tertiary);
  margin-bottom: 48rpx;
}

.empty-btn {
  padding: 24rpx 64rpx;
}

/* ==================== 底部结算栏 ==================== */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 48rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: var(--white-pure);
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.04);
  z-index: 100;
}

.bar-info {
  display: flex;
  flex-direction: column;
}

.bar-count {
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

.bar-right {
  display: flex;
  gap: 16rpx;
}

.bar-btn {
  padding: 24rpx 64rpx;
  border-radius: var(--radius-lg);
  font-size: var(--font-md);
}

/* ==================== 底部留白 ==================== */
.bottom-spacer {
  height: 180rpx;
}
