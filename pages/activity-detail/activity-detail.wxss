/* pages/activity-detail/activity-detail.wxss — 活动详情 */

.page-detail {
  min-height: 100vh;
  background: #FAFAF8;
}

/* 顶部导航 */
.header {
  padding: 104rpx 40rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 32rpx;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 36rpx;
  color: #2C2C2C;
}

.back-btn-placeholder {
  width: 64rpx;
}

.page-title {
  font-family: Georgia, "Songti SC", serif;
  font-size: 28rpx;
  color: #2C2C2C;
  letter-spacing: 2rpx;
}

/* 活动大图 */
.image-area {
  width: 100%;
}

.detail-img {
  width: 100%;
  display: block;
}

/* 信息区 */
.info-area {
  padding: 40rpx 56rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.detail-title {
  font-family: Georgia, "Songti SC", serif;
  font-size: 40rpx;
  color: #2C2C2C;
  line-height: 1.3;
}

.detail-subtitle {
  font-size: 26rpx;
  font-weight: 300;
  color: #888888;
  line-height: 1.6;
}

.detail-date {
  font-size: 22rpx;
  font-weight: 400;
  color: #AAAAAA;
  letter-spacing: 2rpx;
  margin-top: 8rpx;
}
