/* pages/products/products.wxss - 赛宝特产品页（喜茶式高级极简点单风） */

page {
  --color-bg: #FDFCFA;
  --color-nav: #2D2D2D;
  --color-card-bg: #FFFFFF;
  --color-text-primary: #2D2D2D;
  --color-text-secondary: #8C8C8C;
  --color-text-light: #BFBFBF;
  --color-tag-border: #E8E6E1;
  --color-tag-gold: #C4A87C;
  --color-divider: #EFEDE8;
  --color-price: #2D2D2D;
  --color-green-accent: #3A6B4F;
  --color-banner-bg: #F7F5F0;
}

.page-products {
  min-height: 100vh;
  background: var(--color-bg);
  display: flex;
  flex-direction: column;
}

/* ==================== 顶部深炭灰色导航区 ==================== */
.top-nav {
  background: #2A2A2A;
  padding: 0 28rpx;
}

/* 状态栏占位 — 适配刘海/灵动岛 */
.status-bar-placeholder {
  height: 44px;
  height: constant(safe-area-inset-top);
  height: env(safe-area-inset-top);
}

.nav-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 100rpx 0 4rpx;
}

.nav-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.store-switch {
  display: flex;
  align-items: center;
}

.switch-item {
  font-size: 24rpx;
  color: rgba(243, 241, 236, 0.5);
  letter-spacing: 1rpx;
}

.switch-item.active {
  font-size: 36rpx;
  color: #F3F1EC;
  font-weight: 600;
}

.store-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.store-name {
  font-size: 34rpx;
  font-weight: 800;
  color: #F3F1EC;
  letter-spacing: 1rpx;
}

.store-dist {
  font-size: 22rpx;
  color: rgba(243, 241, 236, 0.4);
}

/* 一起选横幅 */
.together-banner {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  margin: 6rpx 0 12rpx;
}

.together-sub {
  font-size: 20rpx;
  color: rgba(243, 241, 236, 0.55);
  letter-spacing: 4rpx;
}

/* ==================== 品牌宣传卡片（白底双卡） ==================== */
.brand-section {
  background: linear-gradient(to bottom, #2A2A2A 20%, #FDFCFA 20%);
  padding-bottom: 60rpx;
}

.brand-cards-area {
  display: flex;
  gap: 24rpx;
  padding: 16rpx 28rpx 0;
}

.brand-card-group {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.brand-card-img {
  width: 100%;
  height: 280rpx;
  background: #FFFFFF;
  overflow: hidden;
}

.card-image {
  width: 100%;
  height: 100%;
  display: block;
}

.brand-card-text {
  width: 100%;
  height: 148rpx;
  box-sizing: border-box;
  background: #FFFFFF;
  padding: 16rpx 18rpx 16rpx 38rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 6rpx;
  border: 2rpx solid #EFEDE8;
  border-top: none;
}

.card-title {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  letter-spacing: 4rpx;
  line-height: 1.4;
}

.card-subtitle {
  font-size: 15rpx;
  color: var(--color-text-secondary);
  letter-spacing: 2rpx;
  line-height: 1.3;
}

/* ==================== 主体区域 ==================== */
.main-area {
  flex: 1;
  display: flex;
  padding: 24rpx 0 0;
}

/* 左侧分类导航 */
.category-nav {
  width: 150rpx;
  flex-shrink: 0;
  height: calc(100vh - 520rpx);
  padding: 0;
}

.cat-item {
  padding: 28rpx 0;
  text-align: center;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cat-indicator {
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 4rpx;
  height: 0;
  background: var(--color-text-primary);
  border-radius: 0 4rpx 4rpx 0;
  transition: height 0.2s ease;
}

.cat-item.active .cat-indicator {
  height: 32rpx;
}

.cat-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  letter-spacing: 0.5rpx;
  transition: all 0.2s ease;
}

.cat-item.active .cat-text {
  color: var(--color-text-primary);
  font-weight: 600;
}

/* 右侧商品列表 */
.product-list {
  flex: 1;
  padding: 0 28rpx 0 20rpx;
  height: calc(100vh - 520rpx);
}

/* 分类标题 */
.section-header {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  padding: 0 0 20rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  letter-spacing: 0.5rpx;
}

.section-count {
  font-size: 22rpx;
  color: var(--color-text-light);
}

/* 商品卡片 */
.product-card {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 2rpx solid var(--color-divider);
  gap: 20rpx;
}

.product-card:last-child {
  border-bottom: none;
}

/* 产品图片（白底） */
.product-img-wrap {
  width: 170rpx;
  height: 170rpx;
  flex-shrink: 0;
  background: #FFFFFF;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid var(--color-divider);
}

.product-img {
  width: 100%;
  height: 100%;
}

/* 产品信息 */
.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
  padding: 4rpx 0;
}

.product-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 标签 */
.product-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}

.tag {
  font-size: 18rpx;
  color: var(--color-tag-gold);
  border: 2rpx solid rgba(196, 168, 124, 0.3);
  padding: 2rpx 14rpx;
  border-radius: 999rpx;
  line-height: 1.6;
}

.product-subtitle {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 底部：规格 + 价格/操作 */
.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: auto;
  padding-top: 12rpx;
}

.product-spec {
  font-size: 20rpx;
  color: var(--color-text-light);
}

.price-action {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.price {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-price);
}

.price.contact {
  font-size: 24rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
}

.btn-add {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid var(--color-divider);
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
}

.btn-add-text {
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 300;
  line-height: 1;
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-text {
  font-size: 26rpx;
  color: var(--color-text-light);
}

/* ==================== 底部留白 ==================== */
.bottom-spacer {
  height: 240rpx;
}

/* ==================== 购物车栏（悬浮胶囊） ==================== */
.cart-bar {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: calc(100rpx + env(safe-area-inset-bottom) + 12rpx);
  height: 80rpx;
  background: #FFFFFF;
  border-radius: 40rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
  display: flex;
  align-items: center;
  padding: 0 8rpx;
}

.cart-bar-inner {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100%;
}

/* 左侧：图标 + 文字 */
.cart-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding-left: 8rpx;
  flex-shrink: 0;
}

.cart-icon-wrap {
  position: relative;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cart-emoji {
  font-size: 36rpx;
  line-height: 1;
}

.cart-badge {
  position: absolute;
  top: -6rpx;
  right: -10rpx;
  min-width: 28rpx;
  height: 28rpx;
  background: #D94A4A;
  border-radius: 14rpx;
  font-size: 18rpx;
  color: #FFFFFF;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
  line-height: 1;
  border: 2rpx solid #FFFFFF;
}

.cart-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  white-space: nowrap;
}

/* 右侧：合计 + 按钮 */
.cart-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

.cart-total {
  font-size: 24rpx;
  color: var(--color-text-primary);
  font-weight: 500;
  white-space: nowrap;
}

.cart-price-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.cart-btn {
  height: 56rpx;
  padding: 0 36rpx;
  background: var(--color-green-accent);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.cart-btn text {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.cart-btn.disabled {
  background: #E8E8E8;
}

.cart-btn.disabled text {
  color: #B0B0B0;
}

/* ==================== "+"按钮点击动效 ==================== */
.btn-add.animate {
  animation: addBtnPulse 0.3s ease;
}

@keyframes addBtnPulse {
  0% {
    transform: scale(1);
    border-color: var(--color-divider);
    background: #FFFFFF;
  }
  30% {
    transform: scale(0.85);
    border-color: var(--color-green-accent);
    background: rgba(58, 107, 79, 0.08);
  }
  60% {
    transform: scale(1.08);
    border-color: var(--color-green-accent);
    background: rgba(58, 107, 79, 0.05);
  }
  100% {
    transform: scale(1);
    border-color: var(--color-divider);
    background: #FFFFFF;
  }
}

/* ==================== 购物车详情浮层（底部弹出） ==================== */

/* 遮罩 */
.sheet-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.sheet-overlay.show {
  opacity: 1;
  pointer-events: auto;
}

/* 浮层面板 */
.cart-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1100;
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  max-height: 65vh;
  display: flex;
  flex-direction: column;
}

.cart-sheet.show {
  transform: translateY(0);
}

/* 面板内容（白底圆角） */
.sheet-inner {
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  max-height: 65vh;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 标题栏 */
.sheet-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 20rpx;
  flex-shrink: 0;
}

.sheet-title-wrap {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.sheet-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.sheet-count {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  font-weight: 400;
}

.sheet-close {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #F5F5F5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sheet-close-icon {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1;
}

/* 商品列表 */
.sheet-list {
  flex: 1;
  padding: 0 32rpx;
  max-height: 45vh;
}

/* 商品行 */
.sheet-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid var(--color-divider);
  gap: 16rpx;
}

.sheet-item:last-child {
  border-bottom: none;
}

.sheet-item-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  background: #F9F8F6;
  flex-shrink: 0;
}

.sheet-item-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.sheet-item-name {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sheet-item-spec {
  font-size: 20rpx;
  color: var(--color-text-light);
}

.sheet-item-qty {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 12rpx;
  flex-shrink: 0;
  padding-right: 52rpx;
}

.sheet-item-price {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  transform: translateX(100rpx);
}

.qty-controls {
  display: flex;
  align-items: center;
  gap: 0;
  background: #F5F5F5;
  border-radius: 20rpx;
  overflow: hidden;
}

.qty-btn {
  width: 56rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s ease;
}

.qty-btn:active {
  background: #E8E8E8;
}

.qty-btn-text {
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 400;
  line-height: 1;
}

.qty-num {
  min-width: 48rpx;
  text-align: center;
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

/* 空状态 */
.sheet-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  gap: 12rpx;
}

.sheet-empty-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.sheet-empty-sub {
  font-size: 24rpx;
  color: var(--color-text-light);
}

/* 底栏 */
.sheet-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-top: 2rpx solid var(--color-divider);
  flex-shrink: 0;
  background: #FFFFFF;
}

.sheet-footer-left {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.sheet-footer-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.sheet-footer-price {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.sheet-footer-num {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.sheet-footer-btn {
  height: 56rpx;
  padding: 0 40rpx;
  background: var(--color-green-accent);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sheet-footer-btn text {
  font-size: 28rpx;
  color: #FFFFFF;
  font-weight: 500;
  letter-spacing: 2rpx;
}
