/* pages/splash/splash.wxss - 开屏视频页 */

page {
  overflow: hidden;
  height: 100vh;
  background: #000000;
}

.splash-page {
  width: 100%;
  height: 100vh;
  position: relative;
  overflow: hidden;
}

.splash-video {
  width: 100%;
  height: 100vh;
  position: absolute;
  top: 0;
  left: 0;
}

/* 跳过按钮 - 右上角 */
.skip-btn {
  position: absolute;
  top: 80rpx;
  right: 32rpx;
  z-index: 10;
  padding: 14rpx 36rpx;
  border-radius: 40rpx;
  background: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
  display: flex;
  align-items: center;
  justify-content: center;
}

.skip-btn:active {
  background: rgba(0, 0, 0, 0.6);
}

.skip-text {
  font-size: 26rpx;
  font-weight: 400;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 2rpx;
}

/* 加载提示 */
.loading-area {
  width: 100%;
  height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  letter-spacing: 4rpx;
}

/* 跳过按钮隐藏状态（延迟出现） */
.skip-hidden {
  display: none;
}

/* 调试信息 */
.debug-info {
  position: absolute;
  bottom: 100rpx;
  left: 0;
  right: 0;
  text-align: center;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  z-index: 10;
}
