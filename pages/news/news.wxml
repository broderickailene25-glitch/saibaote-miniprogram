<!--pages/news/news.wxml - 资讯页（全屏封面 + 详情）-->
<view class="page-consult {{showDetail ? '' : 'cover-mode'}}">

  <nav-bar title="资讯" showBack="{{false}}"></nav-bar>

  <!-- ==================== 全屏封面（轮播） ==================== -->
  <view class="fullscreen-cover" wx:if="{{!showDetail}}">
    <swiper
      class="cover-swiper"
      circular
      autoplay="{{false}}"
      current="{{swiperIndex}}"
      bindchange="onSwiperChange"
      duration="300"
    >
      <block wx:for="{{swiperList}}" wx:key="_id">
        <swiper-item class="cover-slide">
          <image src="{{item.cover}}" mode="aspectFill" class="cover-bg"></image>
        </swiper-item>
      </block>
    </swiper>

    <!-- 轮播指示点 -->
    <view class="swiper-dots" wx:if="{{swiperList.length > 1}}">
      <view
        class="swiper-dot {{index === swiperIndex ? 'active' : ''}}"
        wx:for="{{swiperList}}"
        wx:key="_id"
        data-index="{{index}}"
        bindtap="swipeTo"
      ></view>
    </view>

    <!-- 玻璃质感按钮 -->
    <view class="glass-btns">
      <view class="glass-btn glass-btn-primary" bindtap="openArticle">
        <text class="glass-text">点击阅读</text>
      </view>
      <view class="glass-btn glass-btn-secondary" bindtap="showMoreArticles">
        <text class="glass-text">查看更多</text>
        <text class="glass-arrow">→</text>
      </view>
    </view>
  </view>

  <!-- ==================== 文章详情（Esther 编辑排版） ==================== -->
  <scroll-view scroll-y class="detail-scroll" wx:if="{{showDetail && currentItem}}">

    <!-- 返回按钮 -->
    <view class="detail-back" bindtap="closeArticle">
      <text class="back-arrow">←</text>
      <text class="back-label">返回</text>
    </view>

    <!-- 封面图：固定高度裁切 -->
    <view class="detail-cover">
      <image lazy-load src="{{currentItem.image}}" mode="aspectFill" class="cover-img"></image>
    </view>

    <!-- 标题区（编辑风） -->
    <view class="detail-hero">
      <text class="detail-num">01</text>
      <text class="detail-title">{{currentItem.title}}</text>
      <view class="meta-row">
        <text class="meta-col">{{currentItem.column || '农业资讯'}}</text>
        <view class="meta-dot"></view>
        <text class="meta-date">{{currentItem.createTime}}</text>
      </view>
    </view>

    <!-- 正文 -->
    <view class="detail-body">
      <rich-text class="body-rich" nodes="{{currentItem.content}}"></rich-text>
    </view>

    <!-- 底部 -->
    <view class="detail-end">
      <view class="end-line"></view>
      <text class="end-text">END</text>
    </view>

    <view class="bottom-spacer"></view>
  </scroll-view>

  <!-- 自定义TabBar -->
  <custom-tabbar selected="{{3}}" list="{{tabList}}"></custom-tabbar>

</view>
