/* pages/news/news.wxss - 资讯页（文章卡片 + 全屏详情·喜茶极简风） */

page {
  overflow: hidden;
  height: 100vh;
}

.page-consult {
  height: 100vh;
  background: #FFFFFF;
  overflow-y: auto;
}

.page-consult.cover-mode {
  overflow: hidden;
  height: 100vh;
  padding-bottom: 0;
}

/* ==================== 全屏封面 ==================== */
.fullscreen-cover {
  flex: 1;
  width: 100%;
  overflow: hidden;
  position: relative;
}

.cover-swiper {
  width: 100%;
  height: 100%;
}

.cover-slide {
  width: 100%;
  height: 100%;
}

.cover-bg {
  width: 100%;
  height: 100%;
  display: block;
}

/* 轮播指示点 */
.swiper-dots {
  position: absolute;
  bottom: calc(260rpx + env(safe-area-inset-bottom));
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  gap: 12rpx;
  z-index: 10;
  pointer-events: none;
}

.swiper-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.35);
  transition: all 0.3s ease;
  pointer-events: auto;
}

.swiper-dot.active {
  width: 28rpx;
  border-radius: 6rpx;
  background: rgba(255,255,255,0.85);
}

/* ==================== 玻璃质感按钮 ==================== */
.glass-btns {
  position: absolute;
  bottom: calc(140rpx + env(safe-area-inset-bottom));
  left: 0;
  right: 0;
  display: flex;
  justify-content: center;
  gap: 28rpx;
  padding: 0 48rpx;
  pointer-events: none;
}

.glass-btn {
  pointer-events: auto;
  padding: 22rpx 48rpx;
  border-radius: 50rpx;
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.12);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
}

.glass-btn-primary {
  background: rgba(255,255,255,0.08);
  border-color: rgba(255,255,255,0.18);
}

.glass-text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.6);
  font-weight: 400;
  letter-spacing: 5rpx;
}

.glass-arrow {
  font-size: 26rpx;
  color: rgba(255,255,255,0.6);
  line-height: 1;
}

.page-consult.cover-mode {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  height: 100vh;
}

/* ==================== 文章详情（编辑排版） ==================== */
.detail-scroll {
  height: calc(100vh - env(safe-area-inset-bottom));
  background: #FAFAF8;
}

.detail-back {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 56rpx 0;
}

.back-arrow {
  font-size: 28rpx;
  color: #2C2C2C;
  font-weight: 300;
  line-height: 1;
}

.back-label {
  font-size: 22rpx;
  color: #9A9A9A;
  font-weight: 300;
  letter-spacing: 2rpx;
}

/* 封面：满屏宽 + 固定高度裁切 */
.detail-cover {
  width: 100%;
  height: 480rpx;
  overflow: hidden;
  margin-top: 24rpx;
}

.cover-img {
  width: 100%;
  height: 100%;
  display: block;
}

/* 标题区：大编号 + 衬线 + 金色圆点 */
.detail-hero {
  padding: 80rpx 56rpx 56rpx;
}

.detail-num {
  display: block;
  font-family: Georgia, serif;
  font-size: 128rpx;
  font-weight: 200;
  color: #E8E4DE;
  line-height: 1;
  margin-bottom: 16rpx;
}

.detail-title {
  display: block;
  font-family: Georgia, "Songti SC", serif;
  font-size: 72rpx;
  font-weight: 400;
  color: #2C2C2C;
  line-height: 1.3;
  letter-spacing: 6rpx;
}

.meta-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 56rpx;
}

.meta-col {
  font-size: 22rpx;
  color: #D4A373;
  letter-spacing: 8rpx;
  font-weight: 400;
}

.meta-dot {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #D4CBB8;
  flex-shrink: 0;
}

.meta-date {
  font-size: 22rpx;
  color: #B0ACA4;
  letter-spacing: 4rpx;
  font-weight: 300;
}

/* 正文：轻字重 + 宽行距 */
.detail-body {
  padding: 0 56rpx 80rpx;
}

.body-rich {
  font-size: 28rpx;
  color: #6B6B6B;
  font-weight: 300;
  line-height: 2.4;
  letter-spacing: 2rpx;
}

.body-rich h2 {
  font-size: 32rpx;
  font-weight: 400;
  color: #2C2C2C;
  margin: 80rpx 0 24rpx;
  letter-spacing: 4rpx;
  line-height: 1.6;
}

.body-rich h3 {
  font-size: 28rpx;
  font-weight: 400;
  color: #2C2C2C;
  margin: 64rpx 0 20rpx;
  letter-spacing: 2rpx;
  line-height: 1.6;
}

.body-rich p {
  margin-bottom: 28rpx;
}

.body-rich strong {
  font-weight: 400;
  color: #2C2C2C;
}

/* 底部 */
.detail-end {
  padding: 40rpx 56rpx 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.end-line {
  width: 60rpx;
  height: 2rpx;
  background: #2C2C2C;
  opacity: 0.1;
}

.end-text {
  font-size: 20rpx;
  color: #CCC8C0;
  letter-spacing: 12rpx;
  font-weight: 300;
}

/* ==================== 底部留白 ==================== */
.bottom-spacer {
  height: 80rpx;
}
