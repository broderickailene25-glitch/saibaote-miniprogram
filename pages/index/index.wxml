<!--pages/index/index.wxml - 赛宝特首页（图片完整 + 底部留白极简）-->
<view class="page-index">

  <!-- 图片区域：完整展示，无遮挡 -->
  <view class="image-area">
    <image class="hero-img" src="{{heroImage}}" mode="widthFix"></image>
  </view>

  <!-- 底部留白区 -->
  <view class="content-area">

    <!-- 上半：标题+描述 -->
    <view class="content-top">
      <text class="hero-title">探索有机农业</text>
      <view class="divider-line"></view>
      <text class="hero-desc">14项核心专利覆盖有机肥料、预混饲料、生物质农药，1500+有机基地实证品质</text>
    </view>

    <!-- 下半：数据+按钮 -->
    <view class="content-bottom">
      <view class="stats-row">
        <view class="stat-item">
          <text class="stat-num">14</text>
          <text class="stat-label">核心专利</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-num">3</text>
          <text class="stat-label">产品线</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-num">1500+</text>
          <text class="stat-label">有机基地</text>
        </view>
      </view>
      <view class="enter-btn" bindtap="goToProducts">
        <text class="enter-text">探索产品</text>
      </view>
    </view>

  </view>

  <!-- 自定义TabBar -->
  <custom-tabbar selected="{{0}}" list="{{tabList}}"></custom-tabbar>

</view>
