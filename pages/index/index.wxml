<!--pages/index/index.wxml - 赛宝特首页（全屏品牌展示 + 10s轮播）-->
<view class="page-index">

  <!-- 全屏背景（轮播交叉渐隐） -->
  <view class="fullscreen-bg">
    <image src="{{heroImagePrimary}}" mode="widthFix" class="bg-img {{currentBg === 0 ? 'visible' : ''}}"></image>
    <image src="{{heroImageSecondary}}" mode="widthFix" class="bg-img {{currentBg === 1 ? 'visible' : ''}}"></image>
  </view>

  <!-- 底部轮播指示器 -->
  <view class="indicator-dots">
    <view class="dot {{currentBg === 0 ? 'active' : ''}}"></view>
    <view class="dot {{currentBg === 1 ? 'active' : ''}}"></view>
  </view>

  <!-- 主内容：居中排版 -->
  <view class="main-content">

    <!-- 顶部留白 -->
    <view class="top-spacer"></view>

    <!-- 底部信息区 -->
    <view class="bottom-area">
      <view class="info-row">
        <view class="info-item">
          <text class="info-num">14</text>
          <text class="info-label">核心专利</text>
        </view>
        <view class="info-divider"></view>
        <view class="info-item">
          <text class="info-num">3</text>
          <text class="info-label">产品线</text>
        </view>
        <view class="info-divider"></view>
        <view class="info-item">
          <text class="info-num">1500+</text>
          <text class="info-label">有机基地</text>
        </view>
      </view>

      <!-- 进入按钮 -->
      <view class="enter-btn" bindtap="goToProducts">
        <text class="enter-text">探索产品</text>
      </view>
    </view>

  </view>

  <!-- 自定义TabBar -->
  <custom-tabbar selected="{{0}}" list="{{tabList}}"></custom-tabbar>

</view>
