/* pages/index/index.wxss — 无编号极简（C-3方案） */

page {
  overflow: hidden;
  height: 100vh;
}

.page-index {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FAFAF8;
}

/* ==================== 图片区域：完整展示 ==================== */
.image-area {
  width: 100%;
  flex-shrink: 0;
  overflow: hidden;
}

.hero-img {
  width: 100%;
  display: block;
}

/* ==================== 底部留白区 ==================== */
.content-area {
  flex: 1;
  background: #FAFAF8;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 0 56rpx;
  padding-bottom: 240rpx;
}

/* 上半：标题+描述 */
.content-top {
  padding-top: 56rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 28rpx;
}

.hero-title {
  font-family: Georgia, "Songti SC", serif;
  font-size: 52rpx;
  font-weight: 400;
  color: #2C2C2C;
  line-height: 1.3;
  letter-spacing: 4rpx;
  text-align: center;
}

.divider-line {
  width: 64rpx;
  height: 2rpx;
  background: #D4A373;
}

.hero-desc {
  font-size: 24rpx;
  font-weight: 300;
  color: #888888;
  line-height: 1.9;
  text-align: center;
  letter-spacing: 1rpx;
  max-width: 560rpx;
}

/* 下半：数据+按钮 */
.content-bottom {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
  align-items: center;
}

.stats-row {
  display: flex;
  align-items: center;
  gap: 48rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-num {
  font-family: Georgia, "Songti SC", serif;
  font-size: 36rpx;
  font-weight: 400;
  color: #2C2C2C;
  line-height: 1;
}

.stat-label {
  font-size: 18rpx;
  font-weight: 400;
  color: #AAAAAA;
  letter-spacing: 3rpx;
}

.stat-divider {
  width: 1rpx;
  height: 40rpx;
  background: #E8E4E0;
}

/* 按钮：实心深底（对齐产品页） */
.enter-btn {
  width: 100%;
  padding: 28rpx 0;
  background: #2C2C2C;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.2s;
}

.enter-btn:active {
  opacity: 0.85;
}

.enter-text {
  font-size: 22rpx;
  font-weight: 500;
  letter-spacing: 6rpx;
  color: #FAFAF8;
}

/* ==================== 活动弹窗 ==================== */
.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.popup-card {
  width: 580rpx;
  background: #FAFAF8;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
}

.popup-close {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

.popup-close-icon {
  font-size: 40rpx;
  color: #FFFFFF;
  text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.3);
  line-height: 1;
}

.popup-img {
  width: 100%;
  display: block;
}
