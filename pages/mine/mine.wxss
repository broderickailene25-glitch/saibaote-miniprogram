/* pages/mine/mine.wxss - 个人中心页样式（喜茶极简风） */

.page-mine {
  min-height: 100vh;
  background: #FFFFFF;
  padding-bottom: 160rpx;
}

/* ==================== 用户信息 ==================== */
.user-section {
  padding: 64rpx 48rpx 30rpx;
  background: #FFFFFF;
}

.user-card {
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.user-avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #F5F5F5;
  flex-shrink: 0;
}

.user-avatar {
  width: 100%;
  height: 100%;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 36rpx;
  font-weight: 500;
  color: #1A1A1A;
  margin-bottom: 8rpx;
}

.user-desc {
  font-size: 24rpx;
  color: #999999;
}

.user-login-btn {
  padding: 16rpx 36rpx;
  background: #1A1A1A;
  color: #FFFFFF;
  border-radius: 999rpx;
  font-size: 26rpx;
}

/* ==================== 会员入口 ==================== */
.member-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 5rpx;
  padding: 26rpx 32rpx;
}

.member-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.member-text {
  font-size: 26rpx;
  font-weight: 500;
  color: #1A1A1A;
}

.member-arrow {
  font-size: 28rpx;
  color: #CCCCCC;
}

/* ==================== Section ==================== */
.section {
  padding: 25rpx 48rpx 0;
  margin-bottom: 25rpx;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #1A1A1A;
}

.section-more {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.more-text {
  font-size: 26rpx;
  color: #999999;
}

.more-arrow {
  font-size: 26rpx;
  color: #999999;
}

/* ==================== 订单入口 ==================== */
.order-grid {
  display: flex;
  justify-content: space-between;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 36rpx 24rpx;
}

.order-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}

.order-badge {
  min-width: 28rpx;
  height: 28rpx;
  padding: 0 6rpx;
  background: #E53935;
  color: #FFFFFF;
  font-size: 18rpx;
  border-radius: 14rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.order-label {
  font-size: 26rpx;
  font-weight: 500;
  color: #1A1A1A;
}

/* ==================== 功能列表 ==================== */
.func-list {
  display: flex;
  flex-direction: column;
  gap: 0;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
}

.func-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 30rpx 32rpx;
  margin-bottom: 0;
  border-radius: 0;
  box-shadow: none;
  border: none;
  border-bottom: 1rpx solid #F5F5F5;
}

.func-item:last-child {
  border-bottom: none;
}

.func-label {
  flex: 1;
  font-size: 28rpx;
  font-weight: 500;
  color: #1A1A1A;
}

.func-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.func-badge {
  padding: 4rpx 12rpx;
  background: #E53935;
  color: #FFFFFF;
  font-size: 18rpx;
  border-radius: 999rpx;
  min-width: 32rpx;
  text-align: center;
}

.func-arrow {
  font-size: 28rpx;
  color: #999999;
}

/* ==================== 更多服务 ==================== */
.other-grid {
  display: flex;
  background: #FFFFFF;
  border-radius: 24rpx;
}

.other-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0;
  border-right: 1rpx solid #F5F5F5;
}

.other-item:last-child {
  border-right: none;
}

.other-label {
  font-size: 26rpx;
  font-weight: 500;
  color: #1A1A1A;
}

/* ==================== 版本信息 ==================== */
.version-info {
  text-align: center;
  padding: 48rpx;
}

.version-text {
  font-size: 24rpx;
  color: #CCCCCC;
}

/* ==================== 底部留白 ==================== */
.bottom-spacer {
  height: 40rpx;
}
