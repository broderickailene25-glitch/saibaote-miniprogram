<!--pages/contact/contact.wxml - 联系客服页-->
<view class="page-contact page-enter">

  <nav-bar title="联系客服" showBack="{{true}}" bind:lefttap="onNavBack"></nav-bar>

  <!-- 客服头图 -->
  <view class="hero-section">
    <view class="hero-content">
      <text class="hero-icon">💬</text>
      <text class="hero-title">联系我们</text>
      <text class="hero-subtitle">竭诚为您服务</text>
    </view>
  </view>

  <!-- 联系方式 -->
  <view class="section contact-section">
    <view class="section-title">
      <text class="title-text">联系方式</text>
    </view>
    <view class="contact-list">
      <view class="contact-item card ripple" bindtap="callPhone">
        <view class="contact-icon-wrap">
          <text class="contact-icon">📞</text>
        </view>
        <view class="contact-info">
          <text class="contact-label">客服电话</text>
          <text class="contact-value">400-XXX-XXXX</text>
          <text class="contact-note">工作时间：9:00-18:00</text>
        </view>
        <text class="contact-arrow">→</text>
      </view>

      <view class="contact-item card ripple" bindtap="copyWechat">
        <view class="contact-icon-wrap">
          <text class="contact-icon">💚</text>
        </view>
        <view class="contact-info">
          <text class="contact-label">微信客服</text>
          <text class="contact-value">SaibaoteService</text>
          <text class="contact-note">添加微信，一对一咨询</text>
        </view>
        <text class="contact-arrow">→</text>
      </view>

      <view class="contact-item card ripple" bindtap="sendEmail">
        <view class="contact-icon-wrap">
          <text class="contact-icon">📧</text>
        </view>
        <view class="contact-info">
          <text class="contact-label">电子邮箱</text>
          <text class="contact-value">service@saibaote.com</text>
          <text class="contact-note">24小时内回复</text>
        </view>
        <text class="contact-arrow">→</text>
      </view>

      <view class="contact-item card ripple" bindtap="openLocation">
        <view class="contact-icon-wrap">
          <text class="contact-icon">📍</text>
        </view>
        <view class="contact-info">
          <text class="contact-label">公司地址</text>
          <text class="contact-value">广东省深圳市</text>
          <text class="contact-note">粤港澳大湾区</text>
        </view>
        <text class="contact-arrow">→</text>
      </view>
    </view>
  </view>

  <!-- 在线留言 -->
  <view class="section message-section">
    <view class="section-title">
      <text class="title-text">在线留言</text>
    </view>
    <view class="message-form card">
      <view class="form-item">
        <text class="form-label">您的姓名</text>
        <input class="form-input" placeholder="请输入姓名" value="{{formData.name}}" bindinput="onInput" data-field="name" />
      </view>
      <view class="form-item">
        <text class="form-label">联系电话</text>
        <input class="form-input" placeholder="请输入手机号" type="number" maxlength="11" value="{{formData.phone}}" bindinput="onInput" data-field="phone" />
      </view>
      <view class="form-item">
        <text class="form-label">咨询内容</text>
        <textarea class="form-textarea" placeholder="请描述您的需求或问题" maxlength="500" value="{{formData.content}}" bindinput="onInput" data-field="content"></textarea>
        <text class="form-count">{{formData.content.length}}/500</text>
      </view>
      <view class="btn btn-primary btn-block form-btn ripple" bindtap="submitMessage">
        <text>提交留言</text>
      </view>
    </view>
  </view>

  <!-- 常见问题 -->
  <view class="section faq-section">
    <view class="section-title">
      <text class="title-text">常见问题</text>
    </view>
    <view class="faq-list">
      <view class="faq-item card" wx:for="{{faqs}}" wx:key="question" bindtap="toggleFaq" data-index="{{index}}">
        <view class="faq-question">
          <text class="faq-q-text">{{item.question}}</text>
          <text class="faq-arrow {{expandedFaq === index ? 'expanded' : ''}}">↓</text>
        </view>
        <view class="faq-answer" wx:if="{{expandedFaq === index}}">
          <text class="faq-a-text">{{item.answer}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="bottom-spacer"></view>

</view>
