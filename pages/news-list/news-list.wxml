<!-- pages/news-list/news-list.wxml - 往期文章（整体滚动） -->
<view class="page-news-list">

  <nav-bar title="资讯" showBack="{{true}}" bind:lefttap="onNavBack"></nav-bar>

  <scroll-view class="page-scroll" scroll-y bindscrolltolower="loadMore">

    <!-- 分享横幅 -->
    <share-banner></share-banner>

    <!-- 分类标签栏 -->
    <view class="columns-wrap">
      <scroll-view class="columns-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="columns-list">
          <view
            class="column-item {{activeColumn === item.key ? 'active' : ''}}"
            wx:for="{{columns}}"
            wx:key="key"
            bindtap="switchColumn"
            data-key="{{item.key}}"
          >
            <text class="column-text">{{item.name}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 焦点轮播 -->
    <view class="carousel-section" wx:if="{{carouselList.length > 0}}">
      <text class="section-title">灵感上新</text>
      <view class="carousel-wrap">
        <view class="carousel-arrow arrow-left" bindtap="prevCarousel">
          <text class="arrow-icon">‹</text>
        </view>
        <view class="carousel-image" bindtap="openCarouselArticle">
          <image
            src="{{carouselList[carouselIndex].cover}}"
            mode="aspectFill"
            class="carousel-img"
            lazy-load
          ></image>
          <view class="carousel-overlay">
            <text class="carousel-title">{{carouselList[carouselIndex].title}}</text>
            <text class="carousel-meta">{{carouselList[carouselIndex].column}} · {{carouselList[carouselIndex].createTime}}</text>
          </view>
        </view>
        <view class="carousel-arrow arrow-right" bindtap="nextCarousel">
          <text class="arrow-icon">›</text>
        </view>
      </view>
    </view>

    <!-- 分割线 -->
    <view class="section-divider"></view>

    <!-- 文章列表 -->
    <view class="article-section">
      <view
        class="article-item"
        wx:for="{{filteredArticles}}"
        wx:key="_id"
        bindtap="openArticle"
        data-id="{{item._id}}"
      >
        <view class="article-img-wrap">
          <image lazy-load src="{{item.cover}}" mode="aspectFit" class="article-img"></image>
        </view>
        <view class="article-info">
          <text class="article-title">{{item.title}}</text>
          <view class="article-meta">
            <text class="article-column">{{item.column}}</text>
            <text class="article-dot">·</text>
            <text class="article-time">{{item.createTime}}</text>
          </view>
        </view>
        <text class="article-arrow">→</text>
      </view>

      <view class="empty-state" wx:if="{{filteredArticles.length === 0}}">
        <text class="empty-text">暂无该栏目文章</text>
      </view>
    </view>

    <!-- 底部留白 -->
    <view class="bottom-spacer"></view>

  </scroll-view>

</view>
