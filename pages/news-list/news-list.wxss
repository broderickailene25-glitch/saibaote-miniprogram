/* pages/news-list/news-list.wxss - 往期文章（整体滚动） */

page {
  height: 100vh;
  overflow: hidden;
  background: #FAFAF8;
}

.page-news-list {
  height: 100vh;
  background: #FAFAF8;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.page-scroll {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

/* ==================== 分类标签栏 ==================== */

.columns-wrap {
  background: #FAFAF8;
  padding: 0 36rpx;
}

.columns-scroll {
  white-space: nowrap;
}

.columns-list {
  display: flex;
  gap: 48rpx;
  padding: 28rpx 0 0;
}

.column-item {
  position: relative;
  padding: 8rpx 0 20rpx;
  flex-shrink: 0;
}

.column-text {
  font-size: 30rpx;
  color: #AAAAAA;
  font-weight: 400;
  letter-spacing: 1rpx;
  transition: all 0.2s ease;
}

.column-item.active .column-text {
  color: #2C2C2C;
  font-weight: 500;
}

.column-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 10rpx;
  right: 10rpx;
  height: 3rpx;
  background: #D4A373;
  border-radius: 2rpx;
}

/* ==================== 焦点轮播 ==================== */

.carousel-section {
  padding: 32rpx 36rpx 20rpx;
}

.section-title {
  display: block;
  text-align: center;
  font-family: Georgia, "Songti SC", serif;
  font-size: 36rpx;
  color: #2C2C2C;
  font-weight: 400;
  letter-spacing: 4rpx;
  padding-bottom: 28rpx;
}

.carousel-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.carousel-arrow {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #FFFFFF;
  border: 1rpx solid #E8E4E0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s;
}

.carousel-arrow:active {
  background: #F0EDE8;
}

.arrow-icon {
  font-size: 36rpx;
  color: #888888;
  line-height: 1;
  margin-top: -2rpx;
}

.carousel-image {
  width: 560rpx;
  height: 970rpx;
  border-radius: 8rpx;
  overflow: hidden;
  position: relative;
  flex-shrink: 0;
  background: #EDE9E4;
}

.carousel-img {
  width: 100%;
  height: 100%;
  display: block;
}

.carousel-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 80rpx 24rpx 24rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.5));
}

.carousel-title {
  display: block;
  font-size: 26rpx;
  color: #FFFFFF;
  font-weight: 500;
  line-height: 1.4;
  margin-bottom: 6rpx;
}

.carousel-meta {
  font-size: 20rpx;
  color: rgba(255,255,255,0.7);
}

/* ==================== 文章列表 ==================== */

.article-section {
  padding: 0 36rpx 0;
}

.section-divider {
  height: 2rpx;
  background: #E8E4E0;
  margin: 8rpx 36rpx 0;
}

.bottom-spacer {
  height: 80rpx;
}

.article-item {
  display: flex;
  align-items: center;
  gap: 28rpx;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #EDE9E4;
}

.article-item:last-child {
  border-bottom: none;
}

.article-img-wrap {
  width: 180rpx;
  height: 312rpx;
  border-radius: 6rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: #EDE9E4;
}

.article-img {
  width: 100%;
  height: 100%;
  display: block;
}

.article-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-width: 0;
}

.article-title {
  font-size: 28rpx;
  font-weight: 400;
  color: #2C2C2C;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.article-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.article-column {
  font-size: 22rpx;
  color: #AAAAAA;
}

.article-dot {
  font-size: 22rpx;
  color: #D4CBB8;
}

.article-time {
  font-size: 22rpx;
  color: #C4C0B8;
}

.article-arrow {
  font-size: 28rpx;
  color: #D4CBB8;
  flex-shrink: 0;
}

/* ==================== 空状态 ==================== */

.empty-state {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-text {
  font-size: 24rpx;
  color: #C4C0B8;
  letter-spacing: 2rpx;
}
