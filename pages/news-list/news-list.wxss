/* pages/news-list/news-list.wxss - 往期文章列表（喜茶极简风） */

.page-news-list {
  min-height: 100vh;
  background: #FFFFFF;
  padding-bottom: 120rpx;
}

/* ==================== 栏目筛选 ==================== */
.columns-wrap {
  padding: 36rpx 36rpx 0;
  overflow-x: auto;
}

.columns-list {
  display: flex;
  gap: 48rpx;
}

.column-item {
  position: relative;
  padding: 8rpx 0 24rpx;
}

.column-text {
  font-size: 34rpx;
  color: #999999;
  font-weight: 400;
  transition: all 0.2s ease;
}

.column-item.active .column-text {
  color: #1A1A1A;
  font-weight: 500;
}

.column-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: #1A1A1A;
  border-radius: 2rpx;
}

/* ==================== 文章列表 ==================== */
.article-list {
  padding: 28rpx 36rpx;
}

.article-item {
  display: flex;
  align-items: center;
  gap: 32rpx;
  padding: 32rpx 0;
  border-bottom: 2rpx solid #F0F0F0;
}

.article-item:last-child {
  border-bottom: none;
}

.article-img-wrap {
  width: 220rpx;
  height: 160rpx;
  border-radius: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.article-img {
  width: 100%;
  height: 100%;
  display: block;
}

.article-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  min-width: 0;
}

.article-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #1A1A1A;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.article-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.article-column {
  font-size: 24rpx;
  color: #999999;
}

.article-dot {
  font-size: 24rpx;
  color: #CCCCCC;
}

.article-time {
  font-size: 24rpx;
  color: #CCCCCC;
}

.article-arrow {
  font-size: 32rpx;
  color: #CCCCCC;
  flex-shrink: 0;
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 26rpx;
  color: #CCCCCC;
}
